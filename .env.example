# IntelliAgents — example environment variables (no secrets)
# Copy this file to `.env` and fill values before running

# ---- LLM PROVIDER ----

# ---- GROQ CONFIGURATION (REQUIRED) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- GOOGLE GEMINI CONFIGURATION (OPTIONAL) ----
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- SEARCH CONFIGURATION ----
TAVILY_API_KEY=

# ---- PERSISTENCE ----
SQLITE_DB_PATH=./intelliagents.db

# ---- API & UI SETTINGS ----
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# ---- AGENT BEHAVIOR ----
MAX_ITERATIONS=2
MIN_QUALITY_SCORE=7
